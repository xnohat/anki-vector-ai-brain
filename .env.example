# Copy this file to .env and fill in your values.
# .env is gitignored, so your secrets stay local.

# Required: your OpenAI API key (used for the GPT brain).
OPENAI_API_KEY=sk-your-key-here

# Optional: which OpenAI model powers Vector's brain.
# Must be a vision-capable chat model so Vector can see through his camera.
# Default is gpt-5.5. If that model is not enabled on your account, set this
# to one you have access to, e.g. gpt-4.1 or gpt-4o.
VECTOR_GPT_MODEL=gpt-5.5

# --- Language ---------------------------------------------------------------
# Language Vector THINKS/REPLIES in (free text, passed to the brain prompt).
VECTOR_LANG=Vietnamese
# Speech-to-text language code for Whisper ("vi" Vietnamese, "en" English,
# empty = auto-detect).
VECTOR_STT_LANG=vi
# Whisper model size: tiny/base/small/medium. 'small' supports Vietnamese well.
VECTOR_STT_MODEL=small

# --- Speech-to-text backend (brain_server /stt) -----------------------------
# "openai" = fast cloud transcription (recommended; the Pi's local Whisper is
# too slow and makes the robot's voice request time out). "local" = offline.
VECTOR_STT_BACKEND=openai
VECTOR_STT_API_MODEL=gpt-4o-mini-transcribe

# --- Unified smart-pet brain (brain_server.py) ------------------------------
VECTOR_BODY=1            # 1 = SDK body (movement/sensors), 0 = voice-only
VECTOR_AUTONOMOUS=1      # autonomous pet behaviour loop
VECTOR_TOUCH=1           # backpack touch -> cuddle (button press is ignored = listen)
VECTOR_AGENT_INTERVAL=150
VECTOR_ACT_DELAY=3.5     # seconds to let the spoken reply finish before moving

# --- Voice (text-to-speech) -------------------------------------------------
# 1 = use OpenAI TTS (proper Vietnamese voice, streamed to Vector's speaker).
# 0 = use Vector's onboard English engine (Vietnamese will sound wrong).
VECTOR_TTS=1
VECTOR_TTS_MODEL=gpt-4o-mini-tts
VECTOR_TTS_VOICE=alloy

# --- Wake word + Agent loop -------------------------------------------------
# Comma-separated wake words (default covers "vector" + Vietnamese pronunciations).
# VECTOR_WAKE_WORDS=vector,véc tơ,vích to
# Seconds between autonomous agent-loop ticks (sense + decide).
VECTOR_AGENT_INTERVAL=90
# Seconds Vector stays "active" after the wake word (follow-ups need no wake word).
VECTOR_CONVO_WINDOW=25
# 1 = enable the autonomous agent loop, 0 = wake-word only.
VECTOR_AUTONOMOUS=1
